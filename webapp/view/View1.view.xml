<mvc:View
    controllerName="test.smartcontrols1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:abc="sap.ui.comp.smarttable"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <content>
            <smartFilterBar:SmartFilterBar
                id="smartFilBar"
                entitySet="Employees"
            >
                <smartFilterBar:controlConfiguration>
                    <smartFilterBar:ControlConfiguration
                        id="empId"
                        visibleInAdvancedArea="true"
                        label="Employee ID"
                        key="EmployeeID"
                    />
                    <smartFilterBar:ControlConfiguration
                        id="firstName"
                        visibleInAdvancedArea="true"
                        label="First Name"
                        key="FirstName"
                    />

                    <smartFilterBar:ControlConfiguration 
                    key="EmployeeType"
                    label="Employee Type"
                    visibleInAdvancedArea="true"
                    index="10"
                    >
                        <smartFilterBar:customControl >

                        <RadioButtonGroup selectedIndex="-1" columns="2" >
                        <RadioButton text="Permanent Emp" ></RadioButton>
                        <RadioButton text="Contract Emp" ></RadioButton>
                        </RadioButtonGroup>

                        </smartFilterBar:customControl>
                    </smartFilterBar:ControlConfiguration>


                </smartFilterBar:controlConfiguration>
            </smartFilterBar:SmartFilterBar>

            <abc:SmartTable
                id="smartTable"
                smartFilterId="smartFilBar"
                entitySet="Employees"
                enableAutoBinding="true"
                initiallyVisibleFields="EmployeeID,FirstName,LastName,Title"
                tableType="ResponsiveTable"
            />
        </content>
    </Page>
</mvc:View>
